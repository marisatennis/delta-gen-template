            "displayFolder": "Sales Margin",
            "expression": [
              "IF (",
              "    f_salesinvoices[Sales Margin (MTD)] > f_budgets[Budget Margin (MTD)],",
              "    \"Positive\",",
              "    IF (",
              "        f_salesinvoices[Sales Margin (MTD)] < f_budgets[Budget Margin (MTD)],",
              "        \"Negative\",",
              "        \"No Change\"",
              "    )",
              ")"
            ],
            "lineageTag": "c2a2219c-401a-4f42-82ac-6006132827a2"
          },
          {
            "name": "Sales Margin (YTD vs Budget) ARROW",
            "description": "This measure shows the arrow indicator for the Sales Margin vs Budget Margin comparison for YTD.",
            "displayFolder": "Sales Margin",
            "expression": [
              "IF (",
              "    f_salesinvoices[Sales Margin (YTD)] > f_budgets[Budget Margin (YTD)],",
              "    UNICHAR ( 8593 ),",
              "    IF (",
              "        f_salesinvoices[Sales Margin (YTD)] < f_budgets[Budget Margin (YTD)],",
              "        UNICHAR ( 8595 ),",
              "        UNICHAR ( 45 )",
              "    )",
              ")"
            ],
