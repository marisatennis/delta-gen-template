        "measures": [
          {
            "name": "Budget Margin",
            "changedProperties": [
              {
                "property": "Name"
              },
              {
                "property": "FormatString"
              }
            ],
            "expression": [
              "SWITCH (",
              "    SELECTEDVALUE ( 'S_Currency'[Currency], \"None\" ),",
              "    \"GBP\", SUM ( 'f_budgets'[Gross Margin_ G B P] ),",
              "    \"EUR\", SUM ( 'f_budgets'[Gross Margin_ E U R] ),",
              "    \"USD\", SUM ( 'f_budgets'[Gross Margin_ U S D] )",
              ")"
