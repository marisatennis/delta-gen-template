              "    ISBLANK ( [Stock Volume (PMTD)] ),",
              "    BLANK (),",
              "    DIVIDE (",
              "        [Stock Volume (MTD)] - [Stock Volume (PMTD)],",
              "        [Stock Volume (PMTD)],",
              "        0",
              "    )",
              ")"
            ],
            "formatString": "#0.0%#",
            "lineageTag": "81e94b0b-0bf2-47d0-8416-cf759b306902"
          },
          {
            "name": "Stock Volume (MTD vs PMTD) ARROW",
            "description": "This measure is a derivative of Stock Volume.",
            "displayFolder": "Stock Volume",
            "expression": [
              "IF (",
              "    [Stock Volume (MTD vs PMTD)] > 0,",
              "    UNICHAR ( 8593 ),",
              "    IF ( [Stock Volume (MTD vs PMTD)] = 0, UNICHAR ( 45 ), UNICHAR ( 8595 ) )",
              ")"
            ],
            "lineageTag": "99fd363a-5c76-4848-93b7-3dbba914ca06"
          },
          {
            "name": "Stock Volume (YTD vs PYTD)",
            "displayFolder": "Stock Volume",
            "expression": [
              "IF (",
              "    ISBLANK ( [Stock Volume (PYTD)] ),",
              "    BLANK (),",
              "    DIVIDE (",
              "        [Stock Volume (YTD)] - [Stock Volume (PYTD)],",
              "        [Stock Volume (PYTD)],",
              "        0",
              "    )",
              ")"
            ],
            "formatString": "#0.0%#",
            "lineageTag": "be4282f7-0144-416d-8d61-d909896a70cb"
          },
          {
            "name": "Stock Volume (YTD vs PYTD) ARROW",
            "description": "This measure is a derivative of Stock Volume.",
            "displayFolder": "Stock Volume",
            "expression": [
              "IF (",
              "    [Stock Volume (YTD vs PYTD)] > 0,",
              "    UNICHAR ( 8593 ),",
              "    IF ( [Stock Volume (YTD vs PYTD)] = 0, UNICHAR ( 45 ), UNICHAR ( 8595 ) )",
              ")"
            ],
            "lineageTag": "a4ba82fd-57e4-4609-bc34-76b413cafee7"
          },
          {
            "name": "Volume T (S)",
            "annotations": [
              {
                "name": "PBI_FormatHint",
                "value": "{\"isGeneralNumber\":true}"
              }
            ],
            "changedProperties": [
              {
                "property": "Name"
              }
            ],
            "expression": "CALCULATE(DIVIDE(SUM(f_inventorysnapshot[Volume]), 1000), FILTER(d_unit, d_unit[Unit] <> \"EACH\"))",
            "lineageTag": "f410a168-681e-471b-9e7d-6f560b698788"
          },
          {
            "name": "Stock Quantity (Today)",
            "annotations": [
              {
                "name": "PBI_FormatHint",
                "value": "{\"isGeneralNumber\":true}"
              }
            ],
            "changedProperties": [
              {
                "property": "Name"
              }
            ],
            "expression": [
              "VAR CurrentDate = TODAY ()",
              "RETURN",
              "    CALCULATE (SUM([Quantity]), 'd_date'[Date] = CurrentDate )"
            ],
            "lineageTag": "0fff166d-e37a-4b86-9d38-0f7cbe236f2b"
          },
          {
            "name": "Quantity (excl. 0)",
            "changedProperties": [
              {
                "property": "Name"
              },
              {
                "property": "FormatString"
              }
            ],
            "expression": [
              "CALCULATE(",
              "    SUM(f_inventorysnapshot[Quantity]),",
              "    FILTER(",
              "        f_inventorysnapshot,",
              "        f_inventorysnapshot[Quantity] <> 0",
              "    )",
              ")"
            ],
            "formatString": "#,0",
            "lineageTag": "e48f647e-4009-4e8c-b091-049f2e5f0e71"
          },
          {
            "name": "Total Current Stock",
            "annotations": [
              {
                "name": "PBI_FormatHint",
                "value": "{\"isGeneralNumber\":true}"
              }
            ],
            "changedProperties": [
              {
                "property": "Name"
              }
            ],
            "expression": "SUM(f_inventorysnapshot[PhysicalStock])",
            "lineageTag": "9ac066b4-c854-4a78-b8b4-1aecc0768aab"
          },
          {
            "name": "Total On Order",
            "annotations": [
              {
                "name": "PBI_FormatHint",
                "value": "{\"isGeneralNumber\":true}"
              }
            ],
            "changedProperties": [
              {
                "property": "Name"
              }
            ],
            "expression": "SUM(f_inventorysnapshot[OnOrder])",
            "lineageTag": "6402cc9e-7703-46e7-8af2-158c59e00a9f"
          },
          {
            "name": "Consignment Free Stock",
            "annotations": [
              {
                "name": "PBI_FormatHint",
                "value": "{\"isGeneralNumber\":true}"
              }
            ],
            "changedProperties": [
              {
                "property": "Name"
              }
            ],
            "expression": "[Total Current Stock] - [Total On Order]",
            "lineageTag": "f284b1b3-3e8c-4006-82a0-d474c11af678"
          }
        ],
        "partitions": [
