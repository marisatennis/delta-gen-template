          {
            "name": "Stock Value (Today vs Yesterday)",
            "displayFolder": "Stock Value",
            "expression": [
              "IF (",
              "    ISBLANK ( [Stock Value (Yesterday)] ),",
              "    BLANK (),",
              "    DIVIDE (",
              "        [Stock Value (Today)] - [Stock Value (Yesterday)],",
              "        [Stock Value (Yesterday)],",
              "        0",
              "    )",
              ")"
            ],
            "formatString": "#0.0%#",
            "lineageTag": "79144cc6-e399-4b4e-b5e3-40926686072b"
          },
          {
            "name": "Stock Value (Today vs Yesterday) ARROW",
            "description": "This measure is a derivative of Stock Value.",
            "displayFolder": "Stock Value",
            "expression": [
              "IF (",
              "    [Stock Value (Today vs Yesterday)] > 0,",
              "    UNICHAR ( 8593 ),",
              "    IF ( [Stock Value (Today vs Yesterday)] = 0, UNICHAR ( 45 ), UNICHAR ( 8595 ) )",
              ")"
            ],
            "lineageTag": "0e2cfa5c-008f-4de8-bd05-107678fd5b15"
          },
          {
            "name": "Stock Value (MTD vs PMTD)",
            "displayFolder": "Stock Value",
            "expression": [
              "IF (",
              "    ISBLANK ( [Stock Value (PMTD)] ),",
              "    BLANK (),",
              "    DIVIDE ( [Stock Value (MTD)] - [Stock Value (PMTD)], [Stock Value (PMTD)], 0 )",
              ")"
            ],
            "formatString": "#0.0%#",
            "lineageTag": "b77141f5-9f56-4fd0-ad1f-7fbbaf425bfb"
          },
