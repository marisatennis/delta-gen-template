          },
          {
            "name": "Sales Invoiced (MTD vs Budget) TEXT",
            "description": "This measure shows the text comparison (Positive, Negative, No Change) for the Sales Invoiced vs Sales Budget for MTD.",
            "displayFolder": "Sales Invoiced",
            "expression": [
              "IF (",
              "    f_salesinvoices[Sales Invoiced (MTD)] > f_budgets[Sales Budget (MTD)],",
