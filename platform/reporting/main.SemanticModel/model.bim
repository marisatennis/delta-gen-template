        ],
        "lineageTag": "751220dd-b060-4d03-8910-b7b5ca081173",
        "measures": [
          {
            "name": "Average Invoice Value",
            "changedProperties": [
              {
                "property": "Name"
              },
              {
                "property": "FormatString"
              }
            ],
            "expression": [
              "SWITCH (",
              "    SELECTEDVALUE ( 'S_Currency'[Currency], \"None\" ),",
              "    \"GBP\", AVERAGE ( f_salesinvoices[Total Amount_ G B P] ),",
              "    \"EUR\", AVERAGE ( f_salesinvoices[Total Amount_ E U R] ),",
              "    \"USD\", AVERAGE ( f_salesinvoices[Total Amount_ U S D] ),",
              "    AVERAGE ( f_salesinvoices[Total Amount] )",
              ")"
            ],
            "formatString": "#,0.00",
            "lineageTag": "a974a75f-49b0-4b6e-97a2-25457a3d9e3b"
          },
          {
            "name": "Average Invoice Volume",
            "changedProperties": [
              {
                "property": "Name"
              },
              {
                "property": "FormatString"
              }
            ],
            "expression": "CALCULATE(AVERAGE ( f_salesinvoices[Volume] ), FILTER(d_unit, d_unit[Unit] <> \"EACH\"))",
            "formatString": "#,0.00",
            "lineageTag": "adc99e9c-a16d-4e65-8331-34cc8ab16f6f"
          },
          {
            "name": "Average Margin Value",
            "changedProperties": [
              {
                "property": "Name"
              },
              {
                "property": "FormatString"
              }
            ],
            "expression": [
              "SWITCH (",
              "    SELECTEDVALUE ( 'S_Currency'[Currency], \"None\" ),",
              "    \"GBP\", AVERAGE ( f_salesinvoices[Total Margin_ G B P] ),",
              "    \"EUR\", AVERAGE ( f_salesinvoices[Total Margin_ E U R] ),",
              "    \"USD\", AVERAGE ( f_salesinvoices[Total Margin_ U S D] ),",
              "    AVERAGE ( f_salesinvoices[Total Margin] )",
              ")"
            ],
            "formatString": "#,0.00",
            "lineageTag": "7ed8c7c1-91a2-4e57-8df1-217c622881f2"
          },
          {
            "name": "Margin %",
            "changedProperties": [
              {
                "property": "Name"
              },
              {
                "property": "FormatString"
              }
            ],
            "expression": "DIVIDE ( f_salesinvoices[Sales Margin], f_salesinvoices[Sales Invoiced] ) * 100",
            "formatString": "#,0.00",
            "lineageTag": "b73ee800-853e-4fbb-af53-6572d3035932"
          },
          {
            "name": "No. Invoices",
            "changedProperties": [
              {
                "property": "Name"
              },
              {
                "property": "FormatString"
              }
            ],
            "expression": "DISTINCTCOUNT ( f_salesinvoices[SalesInvoiceID] )",
            "formatString": "#,0",
            "lineageTag": "90a79684-26f4-4fc7-ab9c-55831ddbaffb"
          },
          {
            "name": "Sales Invoiced",
            "changedProperties": [
              {
                "property": "Name"
              },
              {
                "property": "FormatString"
              }
            ],
            "expression": [
              "SWITCH (",
              "    SELECTEDVALUE ( 'S_Currency'[Currency], \"None\" ),",
              "    \"GBP\", SUM ( f_salesinvoices[Total Amount_ G B P] ),",
              "    \"EUR\", SUM ( f_salesinvoices[Total Amount_ E U R] ),",
              "    \"USD\", SUM ( f_salesinvoices[Total Amount_ U S D] ),",
              "    SUM ( f_salesinvoices[Total Amount] )",
              ")"
            ],
            "formatString": "#,0.00",
            "lineageTag": "11abb2dd-1f41-4063-ab84-0a21719393a9"
          },
          {
            "name": "Sales Margin",
            "changedProperties": [
              {
                "property": "Name"
              },
              {
                "property": "FormatString"
              }
            ],
            "expression": [
              "SWITCH (",
              "    SELECTEDVALUE ( 'S_Currency'[Currency], \"None\" ),",
              "    \"GBP\", SUM ( f_salesinvoices[Total Margin_ G B P] ),",
              "    \"EUR\", SUM ( f_salesinvoices[Total Margin_ E U R] ),",
              "    \"USD\", SUM ( f_salesinvoices[Total Margin_ U S D] ),",
              "    SUM ( f_salesinvoices[Total Margin] )",
              ")"
            ],
            "formatString": "#,0.00",
            "lineageTag": "0456a4fe-a120-495f-b699-a1548f6e37ed"
          },
          {
            "name": "Sales Volume",
            "changedProperties": [
              {
                "property": "Name"
              },
              {
                "property": "FormatString"
              }
            ],
            "expression": "CALCULATE(SUM ( f_salesinvoices[Volume] ), FILTER(d_unit, d_unit[Unit] <> \"EACH\"))",
            "formatString": "#,0.00",
            "lineageTag": "80654108-a240-4341-a2b8-8d4ff75be656"
          },
          {
            "name": "Total Cost",
            "changedProperties": [
              {
                "property": "Name"
              },
              {
                "property": "FormatString"
              }
            ],
            "expression": [
              "SWITCH (",
              "    SELECTEDVALUE ( 'S_Currency'[Currency], \"None\" ),",
              "    \"GBP\", SUM ( f_salesinvoices[TotalCost_GBP] ),",
              "    \"EUR\", SUM ( f_salesinvoices[TotalCost_EUR] ),",
              "    \"USD\", SUM ( f_salesinvoices[TotalCost_USD] ),",
              "    SUM ( f_salesinvoices[TotalCost] )",
              ")",
              " ",
              ""
            ],
            "formatString": "#,0.00",
            "lineageTag": "a197932f-d619-4c16-8265-412fcdfb2206"
          },
          {
            "name": "No. Customers By Country",
            "changedProperties": [
              {
                "property": "Name"
              },
              {
                "property": "FormatString"
              }
            ],
            "expression": [
              "CALCULATE (",
              "    DISTINCTCOUNT ( f_salesinvoices[FK_CustomerID] ),",
              "    ALLEXCEPT ( d_invoiceaddress, d_invoiceaddress[Country] )",
              ")"
            ],
            "formatString": "#,0",
            "lineageTag": "368ac97a-7fe2-491d-9443-e0c428c36eed"
          },
          {
            "name": "No. Customers By Sales Area",
            "changedProperties": [
              {
                "property": "Name"
              },
              {
                "property": "FormatString"
              }
            ],
            "expression": [
              "CALCULATE (",
              "    DISTINCTCOUNT ( f_salesinvoices[FK_SalesTeamID] ),",
              "    ALLEXCEPT ( d_invoiceaddress, d_invoiceaddress[Country] )",
              ")"
            ],
            "formatString": "#,0",
            "lineageTag": "65dd4f70-9c1a-4438-90ae-5a9d15b10074"
          },
          {
            "name": "Cost Per Unit (Today)",
            "changedProperties": [
              {
                "property": "Name"
              },
              {
                "property": "FormatString"
              }
            ],
            "expression": [
              "VAR CurrentDate =",
              "    TODAY ()",
              "RETURN",
              "    CALCULATE (",
              "        SUM ( f_salesinvoices[Cost Per Unit] ),",
              "        'd_date'[Date] = CurrentDate,",
              "        ALLSELECTED ( 'd_date'[Year], 'd_date'[Financial Year] )",
              "    )"
            ],
            "formatString": "#,0.00",
            "lineageTag": "1e4723aa-dc6b-4dc1-968a-44f2a446b11e"
          },
          {
            "name": "Cost Per Unit (MTD)",
            "changedProperties": [
              {
                "property": "Name"
              },
              {
                "property": "FormatString"
              }
            ],
            "expression": [
              "VAR CurrentDate =",
              "    TODAY ()",
              "VAR StartdateMonth =",
              "    DATE ( YEAR ( CurrentDate ), MONTH ( CurrentDate ), 1 )",
              "RETURN",
              "    CALCULATE (",
              "        SUM ( f_salesinvoices[Cost Per Unit] ),",
              "        'd_date'[Date] >= StartdateMonth",
              "            && 'd_date'[Date] <= CurrentDate,",
              "        ALLSELECTED ( 'd_date'[Year], 'd_date'[Financial Year] )",
              "    )"
            ],
            "formatString": "#,0.00",
            "lineageTag": "9457e3f3-9639-4d4b-bd1c-48fc429971f6"
          },
