            ],
            "description": "This measure is a derivative of No. Purchase Orders.",
            "displayFolder": "No. Purchase Orders",
            "expression": [
              "CALCULATE (",
              "    [No. Purchase Orders],",
              "    REMOVEFILTERS ( d_date ),",
              "    FILTER (",
              "        DATEADD ( d_date[Date], -1, YEAR ),",
              "        d_date[Date]",
              "            <= DATE ( YEAR ( TODAY () - 1 ), MONTH ( TODAY () ), DAY ( TODAY () ) )",
              "    )",
              ")"
            ],
            "formatString": "#,0",
            "lineageTag": "e8851989-d6a8-43e3-8e22-ba54fd2664b9"
          },
          {
            "name": "Spend Volume (YTD)",
            "description": "This measure is a derivative of Spend Volume.",
            "displayFolder": "Spend Volume",
            "expression": "[Spend Volume]",
            "formatStringDefinition": {
              "expression": "[Currency Format String]"
            },
            "lineageTag": "ef43f896-6a02-49f4-acdd-c02d0fb2b216"
          },
          {
            "name": "Spend Volume (PYTD)",
            "description": "This measure is a derivative of Spend Volume.",
            "displayFolder": "Spend Volume",
            "expression": [
              "CALCULATE (",
              "    [Spend Volume],",
              "    REMOVEFILTERS ( d_date ),",
              "    FILTER (",
              "        DATEADD ( d_date[Date], -1, YEAR ),",
              "        d_date[Date]",
              "            <= DATE ( YEAR ( TODAY () - 1 ), MONTH ( TODAY () ), DAY ( TODAY () ) )",
              "    )",
              ")"
            ],
            "formatStringDefinition": {
              "expression": "[Currency Format String]"
            },
            "lineageTag": "a007ddac-c32c-4479-88ca-149349f37f10"
          },
          {
            "name": "Total Spend (Today vs Yesterday)",
            "displayFolder": "Total Spend",
            "expression": [
              "IF (",
              "    ISBLANK ( [Total Spend (Yesterday)] ),",
              "    BLANK (),",
              "    IF (",
              "        ISBLANK ( [Total Spend (Today)] ),",
              "        BLANK (),",
              "        DIVIDE (",
              "            [Total Spend (Today)] - [Total Spend (Yesterday)],",
              "            [Total Spend (Yesterday)],",
              "            0",
              "        )",
              "    )",
              ")"
            ],
            "formatString": "#0.0%#",
            "lineageTag": "62054220-d7f6-4134-8fed-c28b3210d72a"
          },
          {
            "name": "Total Spend (Today vs Yesterday) ARROW",
            "description": "This measure is a derivative of Total Spend.",
            "displayFolder": "Total Spend",
            "expression": [
              "IF (",
              "    [Total Spend (Today vs Yesterday)] > 0,",
              "    UNICHAR ( 8593 ),",
              "    IF (",
              "        [Total Spend (Today vs Yesterday)] = 0,",
              "        UNICHAR ( 45 ),",
              "        IF (",
              "            [Total Spend (Today vs Yesterday)] = BLANK (),",
              "            UNICHAR ( 45 ),",
              "            UNICHAR ( 8595 )",
              "        )",
              "    )",
              ")"
