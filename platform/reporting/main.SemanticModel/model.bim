          {
            "name": "No. Customers By Product (Invoices)",
            "changedProperties": [
              {
                "property": "Name"
              },
              {
                "property": "FormatString"
              }
            ],
            "expression": [
              "CALCULATE (",
              "    DISTINCTCOUNT ( f_salesinvoices[FK_CustomerID] ),",
              "    ALLEXCEPT ( d_product, d_product[Product] )",
              ")"
            ],
            "formatString": "#,0",
            "lineageTag": "0dae3741-eb44-4c17-a8ab-27e41860b7c0"
          },
          {
            "name": "12-Month Average Sales",
            "changedProperties": [
              {
                "property": "Name"
              },
              {
                "property": "FormatString"
              }
            ],
            "expression": [
              "VAR Last12Months =",
              "    DATESINPERIOD ( D_Date[Date], TODAY (), -12, MONTH )",
              "VAR TotalSalesLast12Months =",
              "    CALCULATE (",
              "        [Sales Invoiced],",
              "        Last12Months,",
              "        REMOVEFILTERS ( D_Date[Year], D_Date[Financial Year] )",
              "    )",
              "RETURN",
              "    DIVIDE ( TotalSalesLast12Months, 12 )"
            ],
            "formatString": "#,0.00",
            "lineageTag": "c4817aa0-6e00-4b8e-be4c-3bcd71e0bb1f"
          },
          {
            "name": "12-Month Average Sales per Sales Area",
            "changedProperties": [
              {
                "property": "Name"
              },
              {
                "property": "FormatString"
              }
            ],
            "expression": "DIVIDE ( [12-Month Average Sales], DISTINCTCOUNT ( d_salesarea[Sales Area] ) )",
            "formatString": "#,0.00",
            "lineageTag": "1b86e171-3b95-4660-b828-b80ef69c5277"
          },
          {
            "name": "Sales Area Performance",
            "changedProperties": [
              {
                "property": "Name"
              },
              {
                "property": "FormatString"
              }
            ],
            "expression": [
              "DIVIDE (",
              "    [12-Month Average Sales per Sales Area] - [12-Month Average Sales],",
              "    [12-Month Average Sales]",
              ") * 100"
            ],
            "formatString": "0.00%;-0.00%;0.00%",
            "lineageTag": "b33e7a6c-c5f3-4c1f-8e62-944d6a708af3"
          },
          {
            "name": "12-Month Average Sales (No Area Filter)",
            "changedProperties": [
              {
                "property": "Name"
              },
              {
                "property": "FormatString"
              }
            ],
            "expression": [
              "VAR Last12Months =",
              "    DATESINPERIOD ( D_Date[Date], TODAY (), -12, MONTH )",
              "VAR TotalSalesLast12Months =",
              "    CALCULATE (",
              "        [Sales Invoiced],",
              "        Last12Months,",
              "        REMOVEFILTERS ( D_Date[Year], D_Date[Financial Year] ),",
              "        REMOVEFILTERS ( d_salesarea[Sales Area] )",
              "    )",
              "VAR DistinctSalesAreas =",
              "    CALCULATE (",
              "        DISTINCTCOUNT ( d_salesarea[Sales Area] ),",
              "        REMOVEFILTERS ( d_salesarea[Sales Area] )",
              "    )",
              "RETURN",
              "    DIVIDE ( TotalSalesLast12Months, 12 * DistinctSalesAreas )"
            ],
            "formatString": "#,0.00",
            "lineageTag": "3f78db87-04ff-4da6-961b-4b11c6cb7634"
          },
          {
            "name": "12-Month Average Sales (No Rep Filter)",
            "changedProperties": [
              {
                "property": "Name"
              },
              {
                "property": "FormatString"
              }
            ],
            "expression": [
              "VAR Last12Months =",
              "    DATESINPERIOD ( D_Date[Date], TODAY (), -12, MONTH )",
              "VAR TotalSalesLast12Months =",
              "    CALCULATE (",
              "        [Sales Invoiced],",
              "        Last12Months,",
              "        REMOVEFILTERS ( D_Date[Year], D_Date[Financial Year] ),",
              "        REMOVEFILTERS ( d_salesteam[Full Name] )",
              "    )",
              "VAR DistinctSalesReps =",
              "    CALCULATE (",
              "        DISTINCTCOUNT ( d_salesteam[Full Name] ),",
              "        REMOVEFILTERS ( d_salesteam[Full Name] )",
              "    )",
              "RETURN",
              "    DIVIDE ( TotalSalesLast12Months, 12 * DistinctSalesReps )"
            ],
            "formatString": "#,0.00",
            "lineageTag": "2ca3f32f-b73f-48f0-ad7c-407844678222"
          },
          {
            "name": "12-Month Average Sales per Sales Rep",
            "changedProperties": [
              {
                "property": "Name"
              },
              {
                "property": "FormatString"
              }
            ],
            "expression": "DIVIDE ( [12-Month Average Sales], DISTINCTCOUNT ( d_salesteam[UserID] ) )",
            "formatString": "#,0.00",
            "lineageTag": "2f590478-db57-4bf7-bbc0-0f85e3bea7a6"
          },
          {
            "name": "Sales Area Performance Against Total Avg.",
            "changedProperties": [
              {
                "property": "Name"
              },
              {
                "property": "FormatString"
              }
            ],
            "expression": [
              "DIVIDE (",
              "    [12-Month Average Sales] - [12-Month Average Sales (No Area Filter)],",
              "    [12-Month Average Sales (No Area Filter)]",
              ")"
            ],
            "formatString": "0.00%;-0.00%;0.00%",
            "lineageTag": "8ce6dcb0-0a23-4623-a2a8-3dfc79a0edbe"
          },
          {
            "name": "Sales Rep Performance Against Total Avg.",
            "changedProperties": [
              {
                "property": "Name"
              },
              {
                "property": "FormatString"
              }
            ],
            "expression": [
              "DIVIDE (",
              "    [12-Month Average Sales] - [12-Month Average Sales (No Rep Filter)],",
              "    [12-Month Average Sales (No Rep Filter)]",
              ")"
            ],
            "formatString": "0.00%;-0.00%;0.00%",
            "lineageTag": "174c35d5-88fc-4fa8-89a5-f3c9176714f1"
          },
          {
            "name": "Volume T (Today)",
            "changedProperties": [
              {
                "property": "Name"
              },
              {
                "property": "FormatString"
              }
            ],
            "expression": "DIVIDE ( [Sales Volume (Today)], 1000 )",
            "formatString": "#,0.00",
            "lineageTag": "1fae7d55-9a22-4b13-bb59-573c24075bc1"
          },
          {
            "name": "Volume T (MTD)",
            "changedProperties": [
              {
                "property": "Name"
              },
              {
                "property": "FormatString"
              }
            ],
            "expression": "DIVIDE ( [Sales Volume (MTD)], 1000 )",
            "formatString": "#,0.00",
            "lineageTag": "0e28d4d7-9540-487c-bacb-fa9a88fe5752"
          },
          {
            "name": "Volume T (SI)",
            "annotations": [
              {
                "name": "PBI_FormatHint",
                "value": "{\"isGeneralNumber\":true}"
              }
            ],
            "changedProperties": [
              {
                "property": "Name"
              }
            ],
            "expression": "CALCULATE(DIVIDE(SUM(f_salesinvoices[Volume]), 1000), FILTER(d_unit, d_unit[Unit] <> \"EACH\"))",
            "lineageTag": "b0e8917b-28be-4c03-8e35-2364f441414d"
          },
          {
            "name": "($)Rate",
            "changedProperties": [
              {
                "property": "Name"
              },
              {
                "property": "FormatString"
              }
            ],
            "expression": "DIVIDE([Sum of Total Amount_USD],[Sum of Total Amount_GBP])",
            "formatString": "0.0000",
            "lineageTag": "bf02f389-1f79-4350-beb0-5988d0d42210"
          },
          {
            "name": "(€)Rate",
            "changedProperties": [
              {
                "property": "Name"
              },
              {
                "property": "FormatString"
              }
            ],
            "expression": "DIVIDE([Sum of Total Amount_EUR],[Sum of Total Amount_GBP])",
            "formatString": "0.0000",
            "lineageTag": "c2b0b7a3-e107-4bc3-8399-d4e0f4679bbc"
          },
          {
            "name": "Sales Invoiced (Today)",
            "description": "This measure is a derivative of Sales Invoiced.",
            "displayFolder": "Sales Invoiced",
            "expression": [
              "VAR CurrentDate =",
              "    TODAY ()",
              "RETURN",
              "    CALCULATE (",
              "        [Sales Invoiced],",
              "        'd_date'[Date] = CurrentDate,",
              "        ALLSELECTED ( 'd_date'[Year], 'd_date'[Financial Year] )",
              "    )"
            ],
            "formatStringDefinition": {
              "expression": "[Currency Format String]"
            },
            "lineageTag": "04af343a-1525-4fdf-a810-a8724bacc7e4"
          },
          {
            "name": "Sales Invoiced (Yesterday)",
            "description": "This measure is a derivative of Sales Invoiced.",
            "displayFolder": "Sales Invoiced",
            "expression": [
              "VAR YesterdayDate =",
              "    TODAY () - 1",
              "RETURN",
              "    CALCULATE (",
              "        [Sales Invoiced],",
              "        'd_date'[Date] = YesterdayDate,",
              "        ALLSELECTED ( 'd_date'[Year], 'd_date'[Financial Year] )",
              "    )"
            ],
            "formatStringDefinition": {
              "expression": "[Currency Format String]"
            },
            "lineageTag": "5e76ff8f-db26-49ff-9cdc-3569e66e0aa9"
          },
          {
            "name": "Sales Invoiced (MTD)",
            "description": "This measure is a derivative of Sales Invoiced.",
            "displayFolder": "Sales Invoiced",
            "expression": [
              "VAR CurrentDate =",
              "    TODAY ()",
              "VAR StartdateMonth =",
              "    DATE ( YEAR ( CurrentDate ), MONTH ( CurrentDate ), 1 )",
              "RETURN",
              "    CALCULATE (",
              "        [Sales Invoiced],",
              "        'd_date'[Date] >= StartdateMonth",
              "            && 'd_date'[Date] <= CurrentDate,",
              "        ALLSELECTED ( 'd_date'[Year], 'd_date'[Financial Year] )",
              "    )"
            ],
            "formatStringDefinition": {
              "expression": "[Currency Format String]"
            },
            "lineageTag": "2f6449da-3988-4522-9dfd-a061734967b8"
          },
          {
            "name": "Sales Invoiced (PMTD)",
            "description": "This measure is a derivative of Sales Invoiced.",
            "displayFolder": "Sales Invoiced",
            "expression": [
              "VAR CurrentDate =",
              "    TODAY ()",
              "VAR DaysInMonthSoFar =",
              "    DAY ( CurrentDate )",
              "VAR StartOfPriorMonth =",
              "    EDATE ( DATE ( YEAR ( CurrentDate ), MONTH ( CurrentDate ), 1 ), -1 )",
              "VAR EndOfPriorMonth = StartOfPriorMonth + DaysInMonthSoFar - 1",
              "RETURN",
              "    CALCULATE (",
              "        [Sales Invoiced],",
              "        'd_date'[Date] >= StartOfPriorMonth",
              "            && 'd_date'[Date] <= EndOfPriorMonth,",
              "        ALLSELECTED ( 'd_date'[Year], 'd_date'[Financial Year] )",
              "    )"
            ],
            "formatStringDefinition": {
              "expression": "[Currency Format String]"
            },
