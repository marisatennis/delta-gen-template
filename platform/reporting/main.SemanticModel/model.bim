            ],
            "changedProperties": [
              {
                "property": "Name"
              }
            ],
            "expression": "CALCULATE(SUM(f_purchaseorders[Quantity]), d_purchaseorderstatus[Purchase Order Status] = \"Backorder\")",
            "lineageTag": "274c6a7d-630f-4515-b6f4-e44bad4e0866"
          }
