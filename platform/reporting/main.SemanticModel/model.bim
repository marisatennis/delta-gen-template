          {
            "name": "Order Margin (Today)",
            "description": "This measure is a derivative of Order Margin.",
            "displayFolder": "Order Margin",
            "expression": [
              "VAR CurrentDate =",
              "    TODAY ()",
              "RETURN",
              "    CALCULATE (",
              "        [Order Margin],",
              "        'd_date'[Date] = CurrentDate,",
              "        ALLSELECTED ( 'd_date'[Year], 'd_date'[Financial Year] )",
              "    )"
            ],
            "formatStringDefinition": {
              "expression": "[Currency Format String]"
            },
            "lineageTag": "94c28184-45f7-4fa0-9a03-015ef950df33"
          },
          {
            "name": "Order Margin (Yesterday)",
            "description": "This measure is a derivative of Order Margin.",
            "displayFolder": "Order Margin",
            "expression": [
              "VAR YesterdayDate =",
              "    TODAY () - 1",
              "RETURN",
              "    CALCULATE (",
              "        [Order Margin],",
              "        'd_date'[Date] = YesterdayDate,",
              "        ALLSELECTED ( 'd_date'[Year], 'd_date'[Financial Year] )",
              "    )"
            ],
            "formatStringDefinition": {
              "expression": "[Currency Format String]"
            },
            "lineageTag": "efcd326c-fa73-4b20-bc2e-dc9629aa2765"
          },
          {
            "name": "Order Margin (MTD)",
            "description": "This measure is a derivative of Order Margin.",
            "displayFolder": "Order Margin",
            "expression": [
              "VAR CurrentDate =",
              "    TODAY ()",
              "VAR StartdateMonth =",
              "    DATE ( YEAR ( CurrentDate ), MONTH ( CurrentDate ), 1 )",
              "RETURN",
              "    CALCULATE (",
              "        [Order Margin],",
              "        'd_date'[Date] >= StartdateMonth",
              "            && 'd_date'[Date] <= CurrentDate,",
              "        ALLSELECTED ( 'd_date'[Year], 'd_date'[Financial Year] )",
              "    )"
            ],
            "formatStringDefinition": {
              "expression": "[Currency Format String]"
            },
            "lineageTag": "20cd2a6f-554e-4a19-80ac-a0c00248d32d"
          },
          {
            "name": "Order Margin (PMTD)",
            "description": "This measure is a derivative of Order Margin.",
            "displayFolder": "Order Margin",
            "expression": [
              "VAR CurrentDate =",
              "    TODAY ()",
              "VAR DaysInMonthSoFar =",
              "    DAY ( CurrentDate )",
              "VAR StartOfPriorMonth =",
              "    EDATE ( DATE ( YEAR ( CurrentDate ), MONTH ( CurrentDate ), 1 ), -1 )",
              "VAR EndOfPriorMonth = StartOfPriorMonth + DaysInMonthSoFar - 1",
              "RETURN",
              "    CALCULATE (",
              "        [Order Margin],",
              "        'd_date'[Date] >= StartOfPriorMonth",
              "            && 'd_date'[Date] <= EndOfPriorMonth,",
              "        ALLSELECTED ( 'd_date'[Year], 'd_date'[Financial Year] )",
              "    )"
            ],
            "formatStringDefinition": {
              "expression": "[Currency Format String]"
            },
            "lineageTag": "b1b73972-56e2-4260-9478-d8f723825774"
          },
          {
            "name": "Order Margin (YTD)",
            "description": "This measure is a derivative of Order Margin.",
            "displayFolder": "Order Margin",
            "expression": "[Order Margin]",
            "formatStringDefinition": {
              "expression": "[Currency Format String]"
            },
            "lineageTag": "fe016c11-9021-4eb1-990c-7f5a5a8ed53d"
          },
          {
            "name": "Order Margin (PYTD)",
            "description": "This measure is a derivative of Order Margin.",
            "displayFolder": "Order Margin",
            "expression": [
              "CALCULATE (",
              "    [Order Margin],",
              "    REMOVEFILTERS ( d_date ),",
              "    FILTER (",
              "        DATEADD ( d_date[Date], -1, YEAR ),",
              "        d_date[Date]",
              "            <= DATE ( YEAR ( TODAY () - 1 ), MONTH ( TODAY () ), DAY ( TODAY () ) )",
              "    )",
              ")"
            ],
            "formatStringDefinition": {
              "expression": "[Currency Format String]"
            },
            "lineageTag": "5b72b03d-9bda-4626-9b02-e9604e9b6392"
          },
