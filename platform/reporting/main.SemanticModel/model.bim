        ],
        "lineageTag": "4ded9f42-e552-4c09-9551-71567787f537",
        "measures": [
          {
            "name": "No. Variances",
            "changedProperties": [
              {
                "property": "Name"
              },
              {
                "property": "FormatString"
              }
            ],
            "expression": [
              "CALCULATE (",
              "    COUNTROWS ( F_TankReadings ),",
              "    F_TankReadings[End of Day Variance] <> 0",
              ")"
            ],
            "formatString": "#,0",
            "lineageTag": "ff92510c-44aa-4292-90ba-ac6ec064174f"
          },
          {
            "name": "Total Tank Capacity %",
            "changedProperties": [
              {
                "property": "Name"
              },
              {
                "property": "FormatString"
              }
            ],
            "expression": "DIVIDE ( [Total Volume Held], SUM ( d_tank[Capacity] ) )",
            "formatString": "0.00%;-0.00%;0.00%",
            "lineageTag": "fe8bb2f4-9c0c-484c-b70c-4e05e56c826a"
          },
          {
            "name": "Total Tank Variance",
            "changedProperties": [
              {
                "property": "Name"
              },
              {
                "property": "FormatString"
              }
            ],
            "expression": [
              "CALCULATE (",
              "    SUMX ( f_tankreadings, ABS ( f_tankreadings[End of Day Variance] ) )",
              ")"
            ],
            "formatString": "#,0.00",
            "lineageTag": "bc8493d8-7a4b-4846-abd7-d56d478a5065"
          },
          {
            "name": "Total Volume Held",
            "changedProperties": [
              {
                "property": "Name"
              },
              {
                "property": "FormatString"
              }
            ],
            "expression": "SUM ( f_tankreadings[Closing Tank Reading] )",
            "formatString": "#,0.00",
            "lineageTag": "9cac0c10-0e69-45c6-bbb4-ebb7779d5a14"
          },
          {
            "name": "Total Tank Variance (Today)",
            "description": "This measure is a derivative of Total Tank Variance.",
            "displayFolder": "Total Tank Variance",
            "expression": [
              "VAR CurrentDate =",
              "    TODAY ()",
              "RETURN",
              "    CALCULATE (",
              "        [Total Tank Variance],",
              "        'd_date'[Date] = CurrentDate,",
              "        ALLSELECTED ( 'd_date'[Year], 'd_date'[Financial Year] )",
              "    )"
            ],
            "formatStringDefinition": {
              "expression": "[Currency Format String]"
            },
            "lineageTag": "50799493-b9a5-4ea9-8b75-d1fabfd64fb6"
          },
          {
            "name": "Total Tank Variance (Yesterday)",
            "description": "This measure is a derivative of Total Tank Variance.",
            "displayFolder": "Total Tank Variance",
            "expression": [
              "VAR YesterdayDate =",
              "    TODAY () - 1",
              "RETURN",
              "    CALCULATE (",
              "        [Total Tank Variance],",
              "        'd_date'[Date] = YesterdayDate,",
              "        ALLSELECTED ( 'd_date'[Year], 'd_date'[Financial Year] )",
              "    )"
            ],
            "formatStringDefinition": {
              "expression": "[Currency Format String]"
            },
            "lineageTag": "392b7acb-b0ca-4f87-bb48-3a40cf43ee53"
          },
          {
            "name": "Total Tank Capacity % (Today)",
            "description": "This measure is a derivative of Total Tank Capacity %.",
