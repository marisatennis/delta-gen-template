              "    )"
            ],
            "formatStringDefinition": {
              "expression": "[Currency Format String]"
            },
            "lineageTag": "cfca0c2e-018d-42c0-ace1-0a1fc64b103e"
          },
          {
            "name": "No. Variances (Today)",
            "annotations": [
              {
                "name": "PBI_FormatHint",
                "value": "{\"isCustom\":true}"
              }
            ],
            "changedProperties": [
              {
                "property": "FormatString"
              }
            ],
            "description": "This measure is a derivative of No. Variances.",
            "displayFolder": "No. Variances",
            "expression": [
              "VAR CurrentDate =",
              "    TODAY ()",
              "RETURN",
              "    CALCULATE (",
              "        [No. Variances],",
              "        'd_date'[Date] = CurrentDate,",
              "        ALLSELECTED ( 'd_date'[Year], 'd_date'[Financial Year] )",
              "    )"
            ],
            "formatString": "#,0",
            "lineageTag": "8ae2f6ab-5167-475e-be15-40618d8d5fb9"
          },
          {
            "name": "No. Variances (Yesterday)",
            "annotations": [
              {
                "name": "PBI_FormatHint",
                "value": "{\"isCustom\":true}"
              }
            ],
            "changedProperties": [
              {
                "property": "FormatString"
              }
            ],
            "description": "This measure is a derivative of No. Variances.",
            "displayFolder": "No. Variances",
            "expression": [
              "VAR YesterdayDate =",
              "    TODAY () - 1",
              "RETURN",
              "    CALCULATE (",
              "        [No. Variances],",
              "        'd_date'[Date] = YesterdayDate,",
              "        ALLSELECTED ( 'd_date'[Year], 'd_date'[Financial Year] )",
              "    )"
            ],
            "formatString": "#,0",
            "lineageTag": "914e0b8d-495a-45a1-aeae-25be73cc17db"
          },
          {
            "name": "Total Volume Held (Today)",
            "description": "This measure is a derivative of Total Volume Held.",
            "displayFolder": "Total Volume Held",
            "expression": [
              "VAR CurrentDate =",
              "    TODAY ()",
              "RETURN",
              "    CALCULATE (",
              "        [Total Volume Held],",
              "        'd_date'[Date] = CurrentDate,",
              "        ALLSELECTED ( 'd_date'[Year], 'd_date'[Financial Year] )",
              "    )"
            ],
            "formatStringDefinition": {
              "expression": "[Currency Format String]"
            },
            "lineageTag": "1d1b67a5-1374-44de-bc26-89507820c5b1"
          },
          {
            "name": "Total Volume Held (Yesterday)",
            "description": "This measure is a derivative of Total Volume Held.",
            "displayFolder": "Total Volume Held",
            "expression": [
              "VAR YesterdayDate =",
              "    TODAY () - 1",
              "RETURN",
              "    CALCULATE (",
              "        [Total Volume Held],",
              "        'd_date'[Date] = YesterdayDate,",
              "        ALLSELECTED ( 'd_date'[Year], 'd_date'[Financial Year] )",
              "    )"
            ],
            "formatStringDefinition": {
              "expression": "[Currency Format String]"
            },
            "lineageTag": "91eb2403-6065-49f1-8a99-bdab2366973b"
          },
          {
            "name": "Total Tank Variance (Today vs Yesterday)",
            "displayFolder": "Total Tank Variance",
            "expression": [
              "IF (",
              "    ISBLANK ( [Total Tank Variance (Yesterday)] ),",
              "    BLANK (),",
              "    IF (",
              "        ISBLANK ( [Total Tank Variance (Today)] ),",
              "        BLANK (),",
              "        DIVIDE (",
              "            [Total Tank Variance (Today)] - [Total Tank Variance (Yesterday)],",
              "            [Total Tank Variance (Yesterday)],",
              "            0",
              "        )",
              "    )",
              ")"
            ],
            "formatString": "#0.0%#",
            "lineageTag": "81a43e6a-1d4b-4b82-bf2e-be5601e3383a"
          },
          {
            "name": "Total Tank Variance (Today vs Yesterday) ARROW",
            "description": "This measure is a derivative of Total Tank Variance.",
            "displayFolder": "Total Tank Variance",
            "expression": [
              "IF (",
              "    [Total Tank Variance (Today vs Yesterday)] > 0,",
              "    UNICHAR ( 8593 ),",
              "    IF (",
              "        [Total Tank Variance (Today vs Yesterday)] = 0,",
              "        UNICHAR ( 45 ),",
              "        IF (",
              "            [Total Tank Variance (Today vs Yesterday)] = BLANK (),",
              "            UNICHAR ( 45 ),",
              "            UNICHAR ( 8595 )",
              "        )",
              "    )",
              ")"
            ],
            "lineageTag": "67365b20-6202-4f2d-b750-616d39a9611f"
          },
          {
            "name": "Total Tank Capacity % (Today vs Yesterday)",
            "displayFolder": "Total Tank Capacity %",
            "expression": [
              "IF (",
              "    ISBLANK ( [Total Tank Capacity % (Yesterday)] ),",
              "    BLANK (),",
              "    IF (",
              "        ISBLANK ( [Total Tank Capacity % (Today)] ),",
              "        BLANK (),",
              "        DIVIDE (",
              "            [Total Tank Capacity % (Today)] - [Total Tank Capacity % (Yesterday)],",
              "            [Total Tank Capacity % (Yesterday)],",
              "            0",
              "        )",
              "    )",
              ")"
            ],
            "formatString": "#0.0%#",
            "lineageTag": "adcfe1a5-8434-459a-b4ec-f13fc85b009b"
          },
          {
            "name": "Total Tank Capacity % (Today vs Yesterday) ARROW",
            "description": "This measure is a derivative of Total Tank Capacity %.",
            "displayFolder": "Total Tank Capacity %",
            "expression": [
              "IF (",
              "    [Total Tank Capacity % (Today vs Yesterday)] > 0,",
              "    UNICHAR ( 8593 ),",
              "    IF (",
              "        [Total Tank Capacity % (Today vs Yesterday)] = 0,",
              "        UNICHAR ( 45 ),",
              "        IF (",
              "            [Total Tank Capacity % (Today vs Yesterday)] = BLANK (),",
              "            UNICHAR ( 45 ),",
              "            UNICHAR ( 8595 )",
              "        )",
              "    )",
              ")"
            ],
            "lineageTag": "4f54aec4-d6f2-475e-a154-8ecdb3046c3d"
          },
          {
            "name": "No. Variances (Today vs Yesterday)",
            "displayFolder": "No. Variances",
            "expression": [
              "IF (",
              "    ISBLANK ( [No. Variances (Yesterday)] ),",
              "    BLANK (),",
              "    IF (",
              "        ISBLANK ( [No. Variances (Today)] ),",
              "        BLANK (),",
              "        DIVIDE (",
              "            [No. Variances (Today)] - [No. Variances (Yesterday)],",
              "            [No. Variances (Yesterday)],",
              "            0",
              "        )",
              "    )",
              ")"
            ],
            "formatString": "#0.0%#",
            "lineageTag": "ac9f638a-3cdc-45d6-b001-9fd3408d770c"
          },
          {
            "name": "No. Variances (Today vs Yesterday) ARROW",
            "description": "This measure is a derivative of No. Variances.",
            "displayFolder": "No. Variances",
            "expression": [
              "IF (",
              "    [No. Variances (Today vs Yesterday)] > 0,",
              "    UNICHAR ( 8593 ),",
              "    IF (",
              "        [No. Variances (Today vs Yesterday)] = 0,",
              "        UNICHAR ( 45 ),",
              "        IF (",
              "            [No. Variances (Today vs Yesterday)] = BLANK (),",
              "            UNICHAR ( 45 ),",
              "            UNICHAR ( 8595 )",
              "        )",
