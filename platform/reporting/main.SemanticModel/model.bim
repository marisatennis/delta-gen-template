          {
            "name": "Forward Order Amount (Next Month)",
            "description": "This measure is a derivative of Forward Order Amount.",
            "displayFolder": "Forward Order Amount",
            "expression": [
              "VAR CurrentDate =",
              "    TODAY ()",
              "VAR StartOfNextMonth =",
              "    EOMONTH ( CurrentDate, 0 ) + 1",
              "VAR EndOfNextMonth =",
              "    EOMONTH ( CurrentDate, 1 )",
              "RETURN",
              "    CALCULATE (",
              "        [Forward Order Amount],",
              "        'd_date'[Date] >= StartOfNextMonth",
              "            && 'd_date'[Date] <= EndOfNextMonth,",
              "        ALLSELECTED ( 'd_date'[Year], 'd_date'[Financial Year] )",
              "    )"
            ],
            "formatStringDefinition": {
              "expression": "[Currency Format String]"
            },
            "lineageTag": "e5722f59-a9c0-40a7-b0db-e583074d2c9f"
          },
          {
            "name": "Order Margin (Today vs Yesterday)",
            "displayFolder": "Order Margin",
            "expression": [
              "IF (",
              "    ISBLANK ( [Order Margin (Yesterday)] ),",
              "    BLANK (),",
              "    IF (",
              "        ISBLANK ( [Order Margin (Today)] ),",
              "        BLANK (),",
              "        DIVIDE (",
              "            [Order Margin (Today)] - [Order Margin (Yesterday)],",
              "            [Order Margin (Yesterday)],",
              "            0",
              "        )",
              "    )",
              ")"
            ],
            "formatString": "#0.0%#",
            "lineageTag": "6fa0dd75-f6bb-4b03-a01c-2cfd3d6cb078"
          },
          {
            "name": "Order Margin (Today vs Yesterday) ARROW",
            "description": "This measure is a derivative of Order Margin.",
            "displayFolder": "Order Margin",
            "expression": [
              "IF (",
              "    [Order Margin (Today vs Yesterday)] > 0,",
              "    UNICHAR ( 8593 ),",
              "    IF (",
              "        [Order Margin (Today vs Yesterday)] = 0,",
              "        UNICHAR ( 45 ),",
              "        IF (",
              "            [Order Margin (Today vs Yesterday)] = BLANK (),",
              "            UNICHAR ( 45 ),",
              "            UNICHAR ( 8595 )",
              "        )",
              "    )",
              ")"
            ],
            "lineageTag": "122f722f-0de3-42bc-85a4-09e867a36116"
          },
