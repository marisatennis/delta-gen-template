        "lineageTag": "b6a045f3-a9ba-4336-8895-188fc202c310",
        "measures": [
          {
            "name": "Average Price Per Unit",
            "changedProperties": [
              {
                "property": "Name"
              },
              {
                "property": "FormatString"
              }
            ],
            "expression": [
              "SWITCH (",
              "    SELECTEDVALUE ( 'S_Currency'[Currency] ),",
              "    \"GBP\", AVERAGE ( f_purchaseorders[Price Per Unit_ G B P] ),",
              "    \"EUR\", AVERAGE ( f_purchaseorders[Price Per Unit_ E U R] ),",
              "    \"USD\", AVERAGE ( f_purchaseorders[Price Per Unit_ U S D] )",
              ")"
            ],
            "formatString": "#,0.00",
            "lineageTag": "c6ada620-c0cd-40f6-a5ac-77e44d15a91e"
          },
          {
            "name": "Average Purchase Order Value",
            "changedProperties": [
              {
                "property": "Name"
              },
              {
                "property": "FormatString"
              }
            ],
            "expression": [
              "SWITCH (",
              "    SELECTEDVALUE ( 'S_Currency'[Currency] ),",
              "    \"GBP\", AVERAGE ( f_purchaseorders[Total Amount_ G B P] ),",
              "    \"EUR\", AVERAGE ( f_purchaseorders[Total Amount_ E U R] ),",
              "    \"USD\", AVERAGE ( f_purchaseorders[Total Amount_ U S D] )",
              ")"
            ],
            "formatString": "#,0.00",
            "lineageTag": "48dd00d6-acdf-4500-996a-c8e0b2665395"
          },
          {
            "name": "Spend Volume",
            "changedProperties": [
              {
                "property": "Name"
              },
              {
                "property": "FormatString"
              }
            ],
            "expression": "CALCULATE(SUM( f_purchaseorders[Volume] ), FILTER(d_unit, d_unit[Unit] <> \"EACH\"))",
            "formatString": "#,0.00",
            "lineageTag": "c50c285b-427c-4df5-9ee1-f0f4a2dadf2b"
          },
          {
            "name": "No. Purchase Orders",
            "changedProperties": [
              {
                "property": "Name"
              },
              {
                "property": "FormatString"
              }
            ],
            "expression": "COUNTROWS ( f_purchaseorders )",
            "formatString": "#,0",
            "lineageTag": "3667cb23-b296-44d6-9631-e548fbf2405a"
          },
          {
            "name": "Total Spend",
            "changedProperties": [
              {
                "property": "Name"
              },
              {
                "property": "FormatString"
              }
            ],
            "expression": [
              "SWITCH (",
              "    SELECTEDVALUE ( 'S_Currency'[Currency], \"None\" ),",
              "    \"GBP\", SUM ( f_purchaseorders[Total Amount_ G B P] ),",
              "    \"EUR\", SUM ( f_purchaseorders[Total Amount_ E U R] ),",
              "    \"USD\", SUM ( f_purchaseorders[Total Amount_ U S D] )",
              ")"
            ],
            "formatString": "#,0.00",
            "lineageTag": "f18dcecf-faa1-4e88-933b-eff89f8193f6"
          },
          {
            "name": "Purchase Order Volume",
            "changedProperties": [
              {
                "property": "FormatString"
              }
            ],
            "expression": "CALCULATE(SUM ( f_purchaseorders[Volume] ), FILTER(d_unit, d_unit[Unit] <> \"EACH\"))",
            "formatString": "#,0.00",
            "lineageTag": "1f159211-45dd-42ce-967c-6e33426f1312"
          },
          {
            "name": "Cost Per Unit",
            "changedProperties": [
              {
                "property": "Name"
              },
              {
                "property": "FormatString"
              }
            ],
            "expression": [
              "SWITCH (",
              "    SELECTEDVALUE ( S_Currency[Currency] ),",
              "    \"GBP\", SUM ( f_purchaseorders[Price Per Unit_ G B P] ),",
              "    \"EUR\", SUM ( f_purchaseorders[Price Per Unit_ E U R] ),",
              "    \"USD\", SUM ( f_purchaseorders[Price Per Unit_ U S D] ),",
              "    BLANK ()",
              ")"
            ],
            "formatString": "#,0.00",
            "lineageTag": "24b4f2fb-6cea-447f-b3fe-e651b1527e92"
          },
          {
            "name": "No. Products Per Supplier",
            "changedProperties": [
              {
                "property": "Name"
              },
              {
                "property": "FormatString"
              }
            ],
            "expression": [
              "CALCULATE (",
              "    DISTINCTCOUNT ( f_purchaseorders[FK_ProductID] ),",
              "    ALLEXCEPT ( D_Supplier, d_supplier[Supplier] )",
              ")"
            ],
            "formatString": "#,0",
            "lineageTag": "92dc5153-9d31-44f6-9570-91b963c1ab82"
          },
          {
            "name": "Total Spend (Today)",
            "description": "This measure is a derivative of Total Spend.",
            "displayFolder": "Total Spend",
            "expression": [
              "VAR CurrentDate =",
              "    TODAY ()",
              "RETURN",
              "    CALCULATE (",
              "        [Total Spend],",
              "        'd_date'[Date] = CurrentDate,",
              "        ALLSELECTED ( 'd_date'[Year], 'd_date'[Financial Year] )",
              "    )"
            ],
            "formatStringDefinition": {
              "expression": "[Currency Format String]"
            },
            "lineageTag": "c9c4a140-8536-4c64-9be0-729003ccad37"
          },
          {
            "name": "Total Spend (Yesterday)",
            "description": "This measure is a derivative of Total Spend.",
            "displayFolder": "Total Spend",
            "expression": [
              "VAR YesterdayDate =",
              "    TODAY () - 1",
              "RETURN",
              "    CALCULATE (",
              "        [Total Spend],",
              "        'd_date'[Date] = YesterdayDate,",
              "        ALLSELECTED ( 'd_date'[Year], 'd_date'[Financial Year] )",
              "    )"
            ],
            "formatStringDefinition": {
              "expression": "[Currency Format String]"
            },
            "lineageTag": "82ad8d0d-351d-49c8-9cc0-2090f35af337"
          },
          {
            "name": "Total Spend (MTD)",
            "description": "This measure is a derivative of Total Spend.",
            "displayFolder": "Total Spend",
            "expression": [
              "VAR CurrentDate =",
              "    TODAY ()",
              "VAR StartdateMonth =",
              "    DATE ( YEAR ( CurrentDate ), MONTH ( CurrentDate ), 1 )",
              "RETURN",
              "    CALCULATE (",
              "        [Total Spend],",
              "        'd_date'[Date] >= StartdateMonth",
              "            && 'd_date'[Date] <= CurrentDate,",
              "        ALLSELECTED ( 'd_date'[Year], 'd_date'[Financial Year] )",
              "    )"
            ],
            "formatStringDefinition": {
              "expression": "[Currency Format String]"
            },
            "lineageTag": "c22dfc2f-0d5f-4269-96b2-8c8276280967"
          },
          {
            "name": "Total Spend (PMTD)",
            "description": "This measure is a derivative of Total Spend.",
            "displayFolder": "Total Spend",
            "expression": [
              "VAR CurrentDate =",
              "    TODAY ()",
              "VAR DaysInMonthSoFar =",
              "    DAY ( CurrentDate )",
              "VAR StartOfPriorMonth =",
              "    EDATE ( DATE ( YEAR ( CurrentDate ), MONTH ( CurrentDate ), 1 ), -1 )",
              "VAR EndOfPriorMonth = StartOfPriorMonth + DaysInMonthSoFar - 1",
              "RETURN",
              "    CALCULATE (",
              "        [Total Spend],",
              "        'd_date'[Date] >= StartOfPriorMonth",
              "            && 'd_date'[Date] <= EndOfPriorMonth,",
              "        ALLSELECTED ( 'd_date'[Year], 'd_date'[Financial Year] )",
              "    )"
            ],
            "formatStringDefinition": {
              "expression": "[Currency Format String]"
            },
            "lineageTag": "a2bcaafa-639c-4de9-ba3e-5954acacbb55"
          },
          {
            "name": "Total Spend (YTD)",
            "description": "This measure is a derivative of Total Spend.",
            "displayFolder": "Total Spend",
            "expression": "[Total Spend]",
            "formatStringDefinition": {
              "expression": "[Currency Format String]"
            },
            "lineageTag": "fbbf4f1f-dc22-48fe-94f6-afed9449ead6"
          },
          {
            "name": "Total Spend (PYTD)",
            "description": "This measure is a derivative of Total Spend.",
            "displayFolder": "Total Spend",
            "expression": [
              "CALCULATE (",
              "    [Total Spend],",
              "    REMOVEFILTERS ( d_date ),",
              "    FILTER (",
              "        DATEADD ( d_date[Date], -1, YEAR ),",
              "        d_date[Date]",
              "            <= DATE ( YEAR ( TODAY () - 1 ), MONTH ( TODAY () ), DAY ( TODAY () ) )",
              "    )",
              ")"
            ],
            "formatStringDefinition": {
              "expression": "[Currency Format String]"
            },
            "lineageTag": "b8546498-ca12-45f7-bc4d-39d3c0839ca1"
          },
