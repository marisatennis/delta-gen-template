          {
            "name": "Budget Margin % (MTD)",
            "changedProperties": [
              {
                "property": "FormatString"
              }
            ],
            "description": "This is a derivative of Budget Margin %.",
            "displayFolder": "Budget Margin %",
            "expression": [
              "VAR CurrentDate =",
              "    TODAY ()",
              "VAR StartdateMonth =",
              "    DATE ( YEAR ( CurrentDate ), MONTH ( CurrentDate ), 1 )",
              "RETURN",
              "    CALCULATE (",
              "        [Budget Margin %],",
              "        'd_date'[Date] >= StartdateMonth",
              "            && 'd_date'[Date] <= CurrentDate,",
              "        ALLSELECTED ( 'd_date'[Year], 'd_date'[Financial Year] )",
              "    )"
            ],
            "formatString": "#,0.00",
            "lineageTag": "d969b237-18f1-4905-98fb-66d044d2acbf"
