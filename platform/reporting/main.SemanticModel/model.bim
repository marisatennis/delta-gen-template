        "lineageTag": "8b71497a-572e-47df-9370-ec98e0414efa",
        "measures": [
          {
            "name": "Stock Value",
            "changedProperties": [
              {
                "property": "Name"
              },
              {
                "property": "FormatString"
              }
            ],
            "expression": [
              "AVERAGEX (",
              "    KEEPFILTERS ( VALUES ( 'd_date'[Date] ) ),",
              "    CALCULATE (",
              "        SWITCH (",
              "            SELECTEDVALUE ( S_Currency[Currency], \"None\" ),",
              "            \"GBP\", SUM ( 'f_inventorysnapshot'[Value_ G B P] ),",
              "            \"EUR\", SUM ( 'f_inventorysnapshot'[Value_ E U R] ),",
              "            \"USD\", SUM ( 'f_inventorysnapshot'[Value_ U S D] ),",
              "            BLANK ()",
              "        )",
              "    )",
              ")"
            ],
            "formatString": "#,0.00",
            "lineageTag": "71077796-10df-49d9-840a-7d647f0ebc81"
          },
          {
            "name": "Stock Volume",
            "changedProperties": [
              {
                "property": "Name"
              },
              {
                "property": "FormatString"
              }
            ],
            "expression": [
              "AVERAGEX(",
              "    KEEPFILTERS(VALUES('d_date'[Date])),",
              "    CALCULATE(",
              "        SUM('f_inventorysnapshot'[Volume]),",
              "        FILTER(d_unit, d_unit[Unit] <> \"EACH\")",
              "    )",
              ")"
            ],
            "formatString": "#,0.00",
            "lineageTag": "ea49cbe0-0a82-4711-9573-481794dc0139"
          },
          {
            "name": "F_IS Date",
            "changedProperties": [
              {
                "property": "Name"
              }
            ],
            "expression": "TODAY ()",
            "formatString": "General Date",
            "lineageTag": "90060ae8-4cbd-4aee-bdb9-d04c06de8d43"
          },
          {
            "name": "Sum Quantity",
            "annotations": [
              {
                "name": "PBI_FormatHint",
                "value": "{\"isGeneralNumber\":true}"
              }
            ],
            "changedProperties": [
              {
                "property": "Name"
              },
              {
                "property": "FormatString"
              }
            ],
            "expression": "SUM ( f_inventorysnapshot[Quantity] )",
            "lineageTag": "2b4ad2cb-e314-4971-a2f1-ae5da48be074"
          },
          {
            "name": "Sum Volume",
            "annotations": [
              {
                "name": "PBI_FormatHint",
                "value": "{\"isGeneralNumber\":true}"
              }
            ],
            "changedProperties": [
              {
                "property": "Name"
              },
              {
                "property": "FormatString"
              }
            ],
            "expression": "CALCULATE(SUM ( f_inventorysnapshot[Volume] ), FILTER(d_unit, d_unit[Unit] <> \"EACH\"))",
            "lineageTag": "42783b67-1912-4ee6-9fec-260e91eb5f38"
          },
          {
            "name": "Free Stock",
            "annotations": [
              {
                "name": "PBI_FormatHint",
                "value": "{\"isGeneralNumber\":true}"
              }
            ],
            "changedProperties": [
              {
                "property": "Name"
              },
              {
                "property": "FormatString"
              }
            ],
            "expression": [
              "IF ( [Forward Order Quantity] > 0, [Stock Quantity (Today)] + f_purchaseorders[Purchase Quantity Backorder] - [Forward Order Quantity],",
              "    (  [Stock Quantity (Today)] + f_purchaseorders[Purchase Quantity Backorder] - [Sales Quantity Backorder] ) )"
            ],
            "lineageTag": "2bae5d9c-f3b0-459e-83d4-477dd6747063"
          },
          {
            "name": "Stock Volume T (Today)",
            "annotations": [
              {
                "name": "PBI_FormatHint",
                "value": "{\"isGeneralNumber\":true}"
              }
            ],
            "changedProperties": [
              {
                "property": "Name"
              }
            ],
            "expression": "DIVIDE ( [Stock Volume (Today)], 1000 )",
            "lineageTag": "b528e771-4065-44b3-8251-def130185750"
          },
          {
            "name": "Stock Value (Today)",
            "description": "This measure is a derivative of Stock Value.",
            "displayFolder": "Stock Value",
            "expression": [
              "VAR CurrentDate =",
              "    TODAY ()",
              "RETURN",
              "    CALCULATE (",
              "        [Stock Value],",
              "        'd_date'[Date] = CurrentDate,",
              "        ALLSELECTED ( 'd_date'[Year], 'd_date'[Financial Year] )",
              "    )"
            ],
            "formatStringDefinition": {
              "expression": "[Currency Format String]"
            },
            "lineageTag": "62dc8d41-2024-44a5-8051-c2eeabfb096d"
          },
          {
            "name": "Stock Value (Yesterday)",
            "description": "This measure is a derivative of Stock Value.",
            "displayFolder": "Stock Value",
            "expression": [
              "VAR YesterdayDate =",
              "    TODAY () - 1",
              "RETURN",
              "    CALCULATE (",
              "        [Stock Value],",
              "        'd_date'[Date] = YesterdayDate,",
              "        ALLSELECTED ( 'd_date'[Year], 'd_date'[Financial Year] )",
              "    )"
            ],
            "formatStringDefinition": {
              "expression": "[Currency Format String]"
            },
            "lineageTag": "241eeab3-3492-47ff-95a7-5957fb011c31"
          },
          {
            "name": "Stock Value (MTD)",
            "description": "This measure is a derivative of Stock Value.",
            "displayFolder": "Stock Value",
            "expression": [
              "VAR CurrentDate =",
              "    TODAY ()",
              "VAR StartdateMonth =",
              "    DATE ( YEAR ( CurrentDate ), MONTH ( CurrentDate ), 1 )",
              "RETURN",
              "    CALCULATE (",
              "        [Stock Value],",
              "        'd_date'[Date] >= StartdateMonth",
              "            && 'd_date'[Date] <= CurrentDate,",
              "        ALLSELECTED ( 'd_date'[Year], 'd_date'[Financial Year] )",
              "    )"
            ],
            "formatStringDefinition": {
              "expression": "[Currency Format String]"
            },
            "lineageTag": "ca21da28-8b0b-4d7e-9416-f88952a3b1fe"
          },
          {
            "name": "Stock Value (PMTD)",
            "description": "This measure is a derivative of Stock Value.",
            "displayFolder": "Stock Value",
            "expression": [
              "VAR CurrentDate =",
              "    TODAY ()",
              "VAR DaysInMonthSoFar =",
              "    DAY ( CurrentDate )",
              "VAR StartOfPriorMonth =",
              "    EDATE ( DATE ( YEAR ( CurrentDate ), MONTH ( CurrentDate ), 1 ), -1 )",
              "VAR EndOfPriorMonth = StartOfPriorMonth + DaysInMonthSoFar - 1",
              "RETURN",
              "    CALCULATE (",
              "        [Stock Value],",
              "        'd_date'[Date] >= StartOfPriorMonth",
              "            && 'd_date'[Date] <= EndOfPriorMonth,",
              "        ALLSELECTED ( 'd_date'[Year], 'd_date'[Financial Year] )",
              "    )"
            ],
            "formatStringDefinition": {
              "expression": "[Currency Format String]"
            },
            "lineageTag": "b3304c9b-6fc2-4266-b16f-405126cdbb36"
          },
          {
            "name": "Stock Value (YTD)",
            "description": "This measure is a derivative of Stock Value.",
            "displayFolder": "Stock Value",
            "expression": "[Stock Value]",
            "formatStringDefinition": {
              "expression": "[Currency Format String]"
            },
            "lineageTag": "9780a478-bd42-4e29-a552-ed0bb702d48f"
          },
          {
            "name": "Stock Value (PYTD)",
            "description": "This measure is a derivative of Stock Value.",
            "displayFolder": "Stock Value",
            "expression": [
              "CALCULATE (",
              "    [Stock Value],",
              "    REMOVEFILTERS ( d_date ),",
              "    FILTER (",
              "        DATEADD ( d_date[Date], -1, YEAR ),",
              "        d_date[Date]",
              "            <= DATE ( YEAR ( TODAY () - 1 ), MONTH ( TODAY () ), DAY ( TODAY () ) )",
              "    )",
              ")"
            ],
            "formatStringDefinition": {
              "expression": "[Currency Format String]"
            },
            "lineageTag": "9ab99f9a-415a-458a-9129-9678e437e329"
          },
          {
            "name": "Stock Volume (Today)",
            "description": "This measure is a derivative of Stock Volume.",
