        "lineageTag": "c69e8d5a-13d5-4257-9497-880afaf50193",
        "measures": [
          {
            "name": "Average Order Margin",
            "changedProperties": [
              {
                "property": "Name"
              },
              {
                "property": "FormatString"
              }
            ],
            "expression": [
              "SWITCH (",
              "    SELECTEDVALUE ( 'S_Currency'[Currency] ),",
              "    \"GBP\", AVERAGE ( f_salesorders[Total Margin_ G B P] ),",
              "    \"EUR\", AVERAGE ( f_salesorders[Total Margin_ E U R] ),",
              "    \"USD\", AVERAGE ( f_salesorders[Total Margin_ U S D] )",
              ")"
            ],
            "formatString": "#,0.00",
            "lineageTag": "4702e609-9f9e-400a-b5fd-83bc356fe42e"
          },
          {
            "name": "Average Order Value",
            "changedProperties": [
              {
                "property": "Name"
              },
              {
                "property": "FormatString"
              }
            ],
            "expression": [
              "SWITCH (",
              "    SELECTEDVALUE ( 'S_Currency'[Currency] ),",
              "    \"GBP\", AVERAGE ( f_salesorders[Total Amount_ G B P] ),",
              "    \"EUR\", AVERAGE ( f_salesorders[Total Amount_ E U R] ),",
              "    \"USD\", AVERAGE ( f_salesorders[Total Amount_ U S D] )",
              ")"
            ],
            "formatString": "#,0.00",
            "lineageTag": "cde35631-2cca-40cd-a491-fab1ef991b08"
          },
          {
            "name": "Average Order Volume",
            "changedProperties": [
              {
                "property": "Name"
              },
              {
                "property": "FormatString"
              }
            ],
            "expression": "CALCULATE(AVERAGE ( f_salesorders[Volume] ), FILTER(d_unit, d_unit[Unit] <> \"EACH\"))",
            "formatString": "#,0.00",
            "lineageTag": "51fdd79a-e9b2-49a0-ad25-f3adcd29133d"
          },
          {
            "name": "Forward Order Amount",
            "changedProperties": [
              {
                "property": "Name"
              },
              {
                "property": "FormatString"
              }
            ],
            "expression": "CALCULATE ( [Order Value], d_shippingdate[Date] > TODAY () + 14 )",
            "formatString": "#,0.00",
            "lineageTag": "87948430-ad8c-4b37-86fd-e3aa21a793d2"
          },
          {
            "name": "No. Orders",
            "changedProperties": [
              {
                "property": "Name"
              },
              {
                "property": "FormatString"
              }
            ],
            "expression": "DISTINCTCOUNT ( f_salesorders[SalesOrderID] )",
            "formatString": "#,0",
            "lineageTag": "b9993e62-3f4c-408e-9290-9c9a6ef03500"
          },
          {
            "name": "Order Margin",
            "changedProperties": [
              {
                "property": "Name"
              },
              {
                "property": "FormatString"
              }
            ],
            "expression": [
              "SWITCH (",
              "    SELECTEDVALUE ( 'S_Currency'[Currency], \"None\" ),",
              "    \"GBP\", SUM ( f_salesorders[Total Margin_ G B P] ),",
              "    \"EUR\", SUM ( f_salesorders[Total Margin_ E U R] ),",
              "    \"USD\", SUM ( f_salesorders[Total Margin_ U S D] )",
              ")"
            ],
            "formatString": "#,0.00",
            "lineageTag": "4da8ee8a-9db9-408f-86e7-66ea40d04b8c"
          },
          {
            "name": "Order Volume",
            "changedProperties": [
              {
                "property": "Name"
              },
              {
                "property": "FormatString"
              }
            ],
            "expression": [
              "CALCULATE(SUM ( f_salesorders[Volume] ), FILTER(d_unit, d_unit[Unit] <> \"EACH\"))",
              ""
            ],
            "formatString": "#,0.00",
            "lineageTag": "7670f73e-52aa-4783-ad9b-26a319638fd3"
          },
          {
            "name": "Order Value",
            "changedProperties": [
              {
                "property": "Name"
              },
              {
                "property": "FormatString"
              }
            ],
            "expression": [
              "SWITCH (",
              "    SELECTEDVALUE ( 'S_Currency'[Currency], \"None\" ),",
              "    \"GBP\", SUM ( f_salesorders[Total Amount_ G B P] ),",
              "    \"EUR\", SUM ( f_salesorders[Total Amount_ E U R] ),",
              "    \"USD\", SUM ( F_salesorders[Total Amount_ U S D] )",
              ")"
            ],
            "formatString": "#,0.00",
            "lineageTag": "a43b04d0-5c17-44fd-b7fa-3fc350e94144"
          },
          {
            "name": "No. Customers By Country (Orders)",
            "changedProperties": [
              {
                "property": "Name"
              },
              {
                "property": "FormatString"
              }
            ],
            "expression": [
              "CALCULATE (",
              "    DISTINCTCOUNT ( f_salesorders[FK_CustomerID] ),",
              "    ALLEXCEPT ( d_postaladdress, d_postaladdress[Country] )",
              ")"
            ],
            "formatString": "#,0",
            "lineageTag": "319fcaab-8c6f-46e8-b8dc-5286d718517d"
          },
          {
            "name": "No. Orders By Product",
            "changedProperties": [
              {
                "property": "Name"
              },
              {
                "property": "FormatString"
              }
            ],
            "expression": [
              "CALCULATE (",
              "    DISTINCTCOUNT ( f_salesorders[SalesOrderID] ),",
              "    ALLEXCEPT ( d_product, d_product[Product] )",
              ")"
            ],
            "formatString": "#,0",
            "lineageTag": "0f0ed2c9-5afc-42d5-b371-360074474aa8"
          },
          {
            "name": "No. Customers By Product (Orders)",
            "changedProperties": [
              {
                "property": "Name"
              },
              {
                "property": "FormatString"
              }
            ],
            "expression": [
              "CALCULATE (",
              "    DISTINCTCOUNT ( f_salesorders[FK_CustomerID] ),",
              "    ALLEXCEPT ( d_product, d_product[Product] )",
              ")"
            ],
            "formatString": "#,0",
            "lineageTag": "d91fcefb-119d-4eb4-a948-3fbb00600b06"
          },
          {
            "name": "Order Quantity",
            "changedProperties": [
              {
                "property": "Name"
              },
              {
                "property": "FormatString"
              }
            ],
            "expression": "SUM (f_salesorders[Quantity Ordered])",
            "formatString": "#,0",
            "lineageTag": "508db6fe-dadc-498b-9dac-2d5616a59665"
          },
          {
            "name": "Forward Order Quantity",
            "annotations": [
              {
                "name": "PBI_FormatHint",
                "value": "{\"isDecimal\":true}"
              }
            ],
            "changedProperties": [
              {
                "property": "Name"
              },
              {
                "property": "FormatString"
              }
            ],
            "expression": "CALCULATE ( SUM ( [Quantity Ordered] ), d_shippingdate[Date] > TODAY () + 14 )",
            "formatString": "#,0",
            "lineageTag": "1ebc25f6-a320-4745-b4d7-7b2d45de90cc"
          },
