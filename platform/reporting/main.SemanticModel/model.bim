          {
            "name": "Sales Invoiced (MTD vs Budget) ARROW",
            "description": "This measure shows the arrow indicator for the Sales Invoiced vs Sales Budget comparison for MTD.",
            "displayFolder": "Sales Invoiced",
            "expression": [
              "IF (",
              "    f_salesinvoices[Sales Invoiced (MTD)] > f_budgets[Sales Budget (MTD)],",
              "    UNICHAR ( 8593 ),",
              "    IF (",
              "        f_salesinvoices[Sales Invoiced (MTD)] < f_budgets[Sales Budget (MTD)],",
              "        UNICHAR ( 8595 ),",
              "        UNICHAR ( 45 )",
              "    )",
              ")"
            ],
