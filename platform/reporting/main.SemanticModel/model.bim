            "displayFolder": "Order Value",
            "expression": "[Order Value]",
            "formatStringDefinition": {
              "expression": "[Currency Format String]"
            },
            "lineageTag": "7f9e8526-9ef0-434a-bc86-5d79a28de592"
          },
          {
            "name": "Order Value (PYTD)",
            "description": "This measure is a derivative of Order Value.",
            "displayFolder": "Order Value",
            "expression": [
              "CALCULATE (",
              "    [Order Value],",
              "    REMOVEFILTERS ( d_date ),",
              "    FILTER (",
              "        DATEADD ( d_date[Date], -1, YEAR ),",
              "        d_date[Date]",
              "            <= DATE ( YEAR ( TODAY () - 1 ), MONTH ( TODAY () ), DAY ( TODAY () ) )",
              "    )",
              ")"
            ],
            "formatStringDefinition": {
              "expression": "[Currency Format String]"
            },
            "lineageTag": "29d9f697-7ad9-49dd-8c15-ff3f8c801194"
          },
          {
            "name": "Order Value (Today vs Yesterday)",
            "displayFolder": "Order Value",
            "expression": [
              "IF (",
              "    ISBLANK ( [Order Value (Yesterday)] ),",
              "    BLANK (),",
              "    IF (",
              "        ISBLANK ( [Order Value (Today)] ),",
              "        BLANK (),",
              "        DIVIDE (",
              "            [Order Value (Today)] - [Order Value (Yesterday)],",
              "            [Order Value (Yesterday)],",
              "            0",
              "        )",
              "    )",
              ")"
            ],
            "formatString": "#0.0%#",
            "lineageTag": "78feb05a-9549-468e-b254-46d34089565d"
          },
          {
            "name": "Order Value (Today vs Yesterday) ARROW",
            "description": "This measure is a derivative of Order Value.",
            "displayFolder": "Order Value",
            "expression": [
              "IF (",
              "    [Order Value (Today vs Yesterday)] > 0,",
              "    UNICHAR ( 8593 ),",
              "    IF (",
              "        [Order Value (Today vs Yesterday)] = 0,",
              "        UNICHAR ( 45 ),",
              "        IF (",
              "            [Order Value (Today vs Yesterday)] = BLANK (),",
              "            UNICHAR ( 45 ),",
              "            UNICHAR ( 8595 )",
              "        )",
              "    )",
              ")"
            ],
            "lineageTag": "8bb94a8e-baf4-4d63-8965-4f28b041ed83"
          },
          {
            "name": "Order Value (MTD vs PMTD)",
            "displayFolder": "Order Value",
            "expression": [
              "IF (",
              "    ISBLANK ( [Order Value (PMTD)] ),",
              "    BLANK (),",
              "    IF (",
              "        ISBLANK ( [Order Value (MTD)] ),",
              "        BLANK (),",
              "        DIVIDE ( [Order Value (MTD)] - [Order Value (PMTD)], [Order Value (PMTD)], 0 )",
              "    )",
              ")"
            ],
            "formatString": "#0.0%#",
            "lineageTag": "165cdc02-09f1-4a59-97dd-ba020daca6f1"
          },
          {
            "name": "Order Value (MTD vs PMTD) ARROW",
            "description": "This measure is a derivative of Order Value.",
            "displayFolder": "Order Value",
            "expression": [
              "IF (",
              "    [Order Value (MTD vs PMTD)] > 0,",
              "    UNICHAR ( 8593 ),",
              "    IF (",
              "        [Order Value (MTD vs PMTD)] = 0,",
              "        UNICHAR ( 45 ),",
              "        IF ( [Order Value (MTD vs PMTD)] = BLANK (), UNICHAR ( 45 ), UNICHAR ( 8595 ) )",
              "    )",
              ")"
            ],
            "lineageTag": "761ae0be-aa81-442d-9cf3-6062bf1ed210"
          },
          {
            "name": "Order Value (YTD vs PYTD)",
            "displayFolder": "Order Value",
            "expression": [
              "IF (",
              "    ISBLANK ( [Order Value (PYTD)] ),",
              "    BLANK (),",
              "    IF (",
              "        ISBLANK ( [Order Value (MTD)] ),",
              "        BLANK (),",
              "        DIVIDE ( [Order Value (YTD)] - [Order Value (PYTD)], [Order Value (PYTD)], 0 )",
              "    )",
              ")"
            ],
            "formatString": "#0.0%#",
            "lineageTag": "92334164-4661-41b4-ae88-b367af8718fb"
          },
          {
            "name": "Order Value (YTD vs PYTD) ARROW",
            "description": "This measure is a derivative of Order Value.",
            "displayFolder": "Order Value",
            "expression": [
              "IF (",
              "    [Order Value (YTD vs PYTD)] > 0,",
              "    UNICHAR ( 8593 ),",
              "    IF (",
              "        [Order Value (YTD vs PYTD)] = 0,",
              "        UNICHAR ( 45 ),",
              "        IF ( [Order Value (YTD vs PYTD)] = BLANK (), UNICHAR ( 45 ), UNICHAR ( 8595 ) )",
              "    )",
              ")"
            ],
            "lineageTag": "d4e739e6-936b-47e8-9d28-fe51134a0d8e"
          }
        ],
