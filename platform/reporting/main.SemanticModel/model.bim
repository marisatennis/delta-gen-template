          {
            "name": "Sales Invoiced (Today vs Yesterday)",
            "displayFolder": "Sales Invoiced",
            "expression": [
              "IF (",
              "    ISBLANK ( [Sales Invoiced (Yesterday)] ),",
              "    BLANK (),",
              "    DIVIDE (",
              "        [Sales Invoiced (Today)] - [Sales Invoiced (Yesterday)],",
              "        [Sales Invoiced (Yesterday)],",
              "        0",
              "    )",
              ")"
            ],
            "formatString": "#0.0%#",
            "lineageTag": "ad939800-a48f-43a7-bd5a-15b6b7a80492"
          },
          {
            "name": "Sales Invoiced (Today vs Yesterday) ARROW",
            "description": "This measure is a derivative of Sales Invoiced.",
            "displayFolder": "Sales Invoiced",
            "expression": [
              "IF (",
              "    [Sales Invoiced (Today vs Yesterday)] > 0,",
              "    UNICHAR ( 8593 ),",
              "    IF (",
              "        [Sales Invoiced (Today vs Yesterday)] = 0,",
              "        UNICHAR ( 45 ),",
              "        UNICHAR ( 8595 )",
              "    )",
              ")"
            ],
            "lineageTag": "af4a0409-4c59-4050-9a9c-5c93a5c5e96a"
          },
