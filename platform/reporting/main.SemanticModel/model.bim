          },
          {
            "name": "Volume T (PO)",
            "annotations": [
              {
                "name": "PBI_FormatHint",
                "value": "{\"isGeneralNumber\":true}"
              }
            ],
            "changedProperties": [
              {
                "property": "Name"
              }
            ],
            "expression": "CALCULATE(DIVIDE(SUM(f_purchaseorders[Volume]), 1000), FILTER(d_unit, d_unit[Unit] <> \"EACH\"))",
            "lineageTag": "59a17fad-b04d-46d1-b2fe-640097cf4727"
          },
