        "lineageTag": "3a1375e8-e448-4077-bef9-149e71a9dcdf",
        "measures": [
          {
            "name": "Exchange Rate Value",
            "changedProperties": [
              {
                "property": "Name"
              },
              {
                "property": "FormatString"
              }
            ],
            "expression": "AVERAGE('f_exchangerates'[Exchange Rate] )",
            "formatString": "#,0.0000",
            "lineageTag": "84255b7a-80e5-42a2-819a-6552fbe0b573"
          },
          {
            "name": "Exchange Rate Value (Today)",
            "description": "This measure is a derivative of Exchange Rate Value.",
            "displayFolder": "Exchange Rate Value",
            "expression": [
              "VAR CurrentDate =",
              "    TODAY ()",
              "RETURN",
              "    CALCULATE (",
              "        [Exchange Rate Value],",
              "        'd_date'[Date] = CurrentDate,",
              "        ALLSELECTED ( 'd_date'[Year], 'd_date'[Financial Year] )",
              "    )"
            ],
            "formatStringDefinition": {
              "expression": "[Currency Format String]"
            },
            "lineageTag": "4f738ffe-7060-466e-882d-cba61743980f"
          },
          {
            "name": "Exchange Rate Value (Yesterday)",
            "description": "This measure is a derivative of Exchange Rate Value.",
            "displayFolder": "Exchange Rate Value",
            "expression": [
              "VAR YesterdayDate =",
              "    TODAY () - 1",
              "RETURN",
              "    CALCULATE (",
              "        [Exchange Rate Value],",
              "        'd_date'[Date] = YesterdayDate,",
              "        ALLSELECTED ( 'd_date'[Year], 'd_date'[Financial Year] )",
              "    )"
            ],
            "formatStringDefinition": {
              "expression": "[Currency Format String]"
            },
            "lineageTag": "dd54cd85-c0a6-4718-9cbb-1cc564b8997c"
          },
          {
            "name": "Exchange Rate Value (Today vs Yesterday) ARROW",
            "description": "This measure is a derivative of Exchange Rate Value.",
            "displayFolder": "Exchange Rate Value",
            "expression": "IF(f_exchangerates[Exchange Rate Value (Today)] > f_exchangerates[Exchange Rate Value (Yesterday)], UNICHAR(8593), IF(f_exchangerates[Exchange Rate Value (Today)] < f_exchangerates[Exchange Rate Value (Yesterday)], UNICHAR(8595), UNICHAR(45)))",
            "lineageTag": "21c17036-d9cf-4004-bb00-95474e9105ed"
          }
        ],
        "partitions": [
          {
