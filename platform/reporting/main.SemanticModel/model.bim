          {
            "name": "Sales Invoiced (YTD)",
            "description": "This measure is a derivative of Sales Invoiced.",
            "displayFolder": "Sales Invoiced",
            "expression": "[Sales Invoiced]",
            "formatStringDefinition": {
              "expression": "[Currency Format String]"
            },
            "lineageTag": "f3cbd7ab-2b6c-42ff-9098-c96365061914"
          },
          {
            "name": "Sales Invoiced (PYTD)",
            "description": "This measure is a derivative of Sales Invoiced.",
            "displayFolder": "Sales Invoiced",
            "expression": [
              "CALCULATE (",
              "    [Sales Invoiced],",
              "    REMOVEFILTERS ( d_date ),",
              "    FILTER (",
              "        DATEADD ( d_date[Date], -1, YEAR ),",
              "        d_date[Date]",
              "            <= DATE ( YEAR ( TODAY () - 1 ), MONTH ( TODAY () ), DAY ( TODAY () ) )",
              "    )",
              ")"
            ],
            "formatStringDefinition": {
              "expression": "[Currency Format String]"
            },
            "lineageTag": "8370f5e9-7b3a-4671-bf21-e390fbfc1375"
          },
          {
            "name": "Sales Invoiced (Last Month)",
            "description": "This measure is a derivative of Sales Invoiced.",
            "displayFolder": "Sales Invoiced",
            "expression": [
              "VAR CurrentDate =",
              "    TODAY ()",
              "VAR StartOfLastMonth =",
              "    EOMONTH ( CurrentDate, -2 ) + 1",
              "VAR EndOfLastMonth =",
              "    EOMONTH ( CurrentDate, -1 )",
              "RETURN",
              "    CALCULATE (",
              "        [Sales Invoiced],",
              "        'd_date'[Date] >= StartOfLastMonth",
              "            && 'd_date'[Date] <= EndOfLastMonth,",
              "        ALLSELECTED ( 'd_date'[Year], 'd_date'[Financial Year] )",
              "    )"
            ],
            "formatStringDefinition": {
              "expression": "[Currency Format String]"
            },
            "lineageTag": "e8e7ec96-8610-4952-88af-c2b1311b4368"
          },
          {
            "name": "Sales Margin (Today)",
            "description": "This measure is a derivative of Sales Margin.",
            "displayFolder": "Sales Margin",
            "expression": [
              "VAR CurrentDate =",
              "    TODAY ()",
              "RETURN",
              "    CALCULATE (",
              "        [Sales Margin],",
              "        'd_date'[Date] = CurrentDate,",
              "        ALLSELECTED ( 'd_date'[Year], 'd_date'[Financial Year] )",
              "    )"
            ],
            "formatStringDefinition": {
              "expression": "[Currency Format String]"
            },
            "lineageTag": "4b48ebda-224a-4058-b8f3-4ad21d6de9dd"
          },
          {
            "name": "Sales Margin (Yesterday)",
            "description": "This measure is a derivative of Sales Margin.",
            "displayFolder": "Sales Margin",
            "expression": [
              "VAR YesterdayDate =",
              "    TODAY () - 1",
              "RETURN",
              "    CALCULATE (",
              "        [Sales Margin],",
              "        'd_date'[Date] = YesterdayDate,",
              "        ALLSELECTED ( 'd_date'[Year], 'd_date'[Financial Year] )",
              "    )"
            ],
            "formatStringDefinition": {
              "expression": "[Currency Format String]"
            },
            "lineageTag": "ad26624f-cf74-4646-a018-2dddef36ba07"
          },
          {
            "name": "Sales Margin (MTD)",
            "description": "This measure is a derivative of Sales Margin.",
            "displayFolder": "Sales Margin",
            "expression": [
              "VAR CurrentDate =",
              "    TODAY ()",
              "VAR StartdateMonth =",
              "    DATE ( YEAR ( CurrentDate ), MONTH ( CurrentDate ), 1 )",
              "RETURN",
              "    CALCULATE (",
              "        [Sales Margin],",
              "        'd_date'[Date] >= StartdateMonth",
              "            && 'd_date'[Date] <= CurrentDate,",
              "        ALLSELECTED ( 'd_date'[Year], 'd_date'[Financial Year] )",
              "    )"
            ],
            "formatStringDefinition": {
              "expression": "[Currency Format String]"
            },
            "lineageTag": "9006b1a9-32d4-44a9-867f-d2f88e6c0a7a"
          },
          {
            "name": "Sales Margin (PMTD)",
            "description": "This measure is a derivative of Sales Margin.",
            "displayFolder": "Sales Margin",
            "expression": [
              "VAR CurrentDate =",
              "    TODAY ()",
              "VAR DaysInMonthSoFar =",
              "    DAY ( CurrentDate )",
              "VAR StartOfPriorMonth =",
              "    EDATE ( DATE ( YEAR ( CurrentDate ), MONTH ( CurrentDate ), 1 ), -1 )",
              "VAR EndOfPriorMonth = StartOfPriorMonth + DaysInMonthSoFar - 1",
              "RETURN",
              "    CALCULATE (",
              "        [Sales Margin],",
              "        'd_date'[Date] >= StartOfPriorMonth",
              "            && 'd_date'[Date] <= EndOfPriorMonth,",
              "        ALLSELECTED ( 'd_date'[Year], 'd_date'[Financial Year] )",
              "    )"
            ],
            "formatStringDefinition": {
              "expression": "[Currency Format String]"
            },
            "lineageTag": "c3c38f1b-b219-4e84-997a-de720f5d34cf"
          },
