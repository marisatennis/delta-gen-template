            "expression": [
              "SWITCH (",
              "    SELECTEDVALUE ( 'S_Currency'[Currency], \"None\" ),",
              "    \"GBP\", SUM ( 'f_budgets'[Sales_ G B P] ),",
              "    \"EUR\", SUM ( 'f_budgets'[Sales_ E U R] ),",
              "    \"USD\", SUM ( 'f_budgets'[Sales_ U S D] )",
              ")"
            ],
