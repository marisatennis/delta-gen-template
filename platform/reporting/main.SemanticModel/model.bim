        "lineageTag": "0b9df470-07c8-4c99-b3a8-d731c329a5e0",
        "measures": [
          {
            "name": "Lower Tier Score",
            "annotations": [
              {
                "name": "PBI_FormatHint",
                "value": "{\"isGeneralNumber\":true}"
              }
            ],
            "changedProperties": [
              {
                "property": "Name"
              }
            ],
            "expression": [
              "DIVIDE (",
              "    SUM ( f_comahsnapshot[Total Weight In Tonne] ),",
              "    SUM ( f_comahlimits[Lower Limit] )",
              ")"
            ],
            "lineageTag": "9e680e2b-0db6-4cb1-9854-ab092f2c8c96"
          },
          {
            "name": "Upper Tier Score",
            "annotations": [
              {
                "name": "PBI_FormatHint",
                "value": "{\"isGeneralNumber\":true}"
              }
            ],
            "changedProperties": [
              {
                "property": "Name"
              }
            ],
            "expression": [
              "DIVIDE (",
              "    SUM ( f_comahsnapshot[Total Weight In Tonne] ),",
              "    SUM ( f_comahlimits[Upper Limit] )",
              ")"
            ],
            "lineageTag": "3104901b-ca92-492b-b6a2-67573e19a191"
          },
          {
            "name": "Lower Tier vs Limit",
            "changedProperties": [
              {
                "property": "Name"
              },
              {
                "property": "FormatString"
              }
            ],
            "expression": "( 1 - [Lower Tier Score] )",
            "formatString": "0.00%;-0.00%;0.00%",
            "lineageTag": "0da1363d-a141-4249-ab5a-f662e338f4d7"
          },
          {
            "name": "Upper Tier vs Limit",
            "changedProperties": [
              {
                "property": "Name"
              },
              {
                "property": "FormatString"
              }
            ],
            "expression": "( 1 - [Upper Tier Score] )",
            "formatString": "0.00%;-0.00%;0.00%",
            "lineageTag": "15a3ecc0-b9e3-4ae9-b72c-a5a13ae24950"
          },
          {
            "name": "Lower Score vs Limit ARROW",
            "changedProperties": [
              {
                "property": "Name"
              }
            ],
            "expression": [
              "IF (",
